// Cloudflare Worker to receive Tally webhooks and forward to AI Studio

export default {
  async fetch(request, env) {
    // Only accept POST requests
    if (request.method !== 'POST') {
      return new Response('Method not allowed', { status: 405 });
    }

    try {
      // Parse Tally webhook payload
      const tallyData = await request.json();
      
      // Validate it's the event we expect
      if (tallyData.event !== 'form.submission.created') {
        return new Response('Event type not supported', { status: 200 });
      }

      // Transform Tally data to AI Studio format
      const aiStudioPayload = transformTallyData(tallyData);
      
      // Call AI Studio API
      const aiStudioResponse = await callAIStudio(aiStudioPayload, env);
      
      // Return success to Tally (important: respond quickly!)
      return new Response(JSON.stringify({ 
        success: true, 
        message: 'Webhook received and processed',
        aiStudioResponse 
      }), {
        status: 200,
        headers: { 'Content-Type': 'application/json' }
      });
      
    } catch (error) {
      console.error('Webhook processing error:', error);
      
      // Still return 200 to Tally to prevent retries
      // Log error for debugging
      return new Response(JSON.stringify({ 
        success: false, 
        error: error.message 
      }), {
        status: 200,
        headers: { 'Content-Type': 'application/json' }
      });
    }
  }
};

// Transform Tally webhook data to AI Studio format
function transformTallyData(tallyData) {
  const { data } = tallyData;
  
  // Convert Tally fields array to object for easier access
  const fields = {};
  if (data.fields && Array.isArray(data.fields)) {
    data.fields.forEach(field => {
      fields[field.key] = field.value;
    });
  }
  
  return {
    formId: data.formId,
    responseId: data.responseId,
    submittedAt: data.createdAt || new Date().toISOString(),
    fields: fields,
    // Add any other data you need
    metadata: {
      source: 'tally',
      formName: data.formName || 'Unknown'
    }
  };
}

// Call AI Studio API
async function callAIStudio(payload, env) {
  // Replace with your actual AI Studio API endpoint
  const AI_STUDIO_ENDPOINT = env.AI_STUDIO_API_URL;
  const API_KEY = env.AI_STUDIO_API_KEY;
  
  const response = await fetch(AI_STUDIO_ENDPOINT, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${API_KEY}`, // Adjust based on your auth
      // Add any other required headers
    },
    body: JSON.stringify(payload)
  });
  
  if (!response.ok) {
    throw new Error(`AI Studio API error: ${response.status} ${response.statusText}`);
  }
  
  return await response.json();
}
